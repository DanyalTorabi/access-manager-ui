# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Base URL of the access-manager backend
VITE_API_BASE_URL=http://127.0.0.1:8080

# Optional Bearer token — must match API_BEARER_TOKEN on the backend
# Leave empty if the backend is running without authentication
VITE_API_BEARER_TOKEN=
